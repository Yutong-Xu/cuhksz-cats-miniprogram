/* pages/index/index.wxss */
.container {
  padding: 40rpx 32rpx 60rpx;
  min-height: 100vh;
}

.header {
  padding: 20rpx 0 30rpx;
}
.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.subtitle {
  margin-top: 12rpx;
  color: #888;
  font-size: 26rpx;
}

/* 搜索栏 */
.search-bar {
  background: #fff;
  border-radius: 40rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}
.search-icon {
  font-size: 28rpx;
}
.search-placeholder {
  color: #aaa;
  font-size: 26rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 28rpx;
  min-height: 240rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  transition: transform .15s;
}
.card:active {
  transform: scale(0.97);
}
.card-current { background: linear-gradient(135deg, #FFF8E1, #FFECB3); }
.card-history { background: linear-gradient(135deg, #E8EAF6, #C5CAE9); }
.card-adoption { background: linear-gradient(135deg, #E0F7FA, #B2EBF2); }
.card-foster { background: linear-gradient(135deg, #FCE4EC, #F8BBD0); }

.emoji {
  font-size: 64rpx;
}
.card-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-top: 20rpx;
}
.card-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.footer {
  text-align: center;
  color: #aaa;
  font-size: 24rpx;
  margin-top: 80rpx;
}
