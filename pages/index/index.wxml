<!--pages/index/index.wxml-->
<view class="container">
  <view class="header">
    <view class="title">CUHK(SZ) 猫猫图鉴</view>
    <view class="subtitle">记录校园里的每一只小可爱 🐾</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="goToSearch">
    <text class="search-icon">🔍</text>
    <text class="search-placeholder">搜索猫咪名字、位置、性格...</text>
  </view>

  <view class="grid">
    <view class="card card-current" bindtap="goToList" data-status="current" data-title="校内猫猫">
      <view class="emoji">🐱</view>
      <view class="card-title">校内猫猫</view>
      <view class="card-desc">目前在校园里的猫</view>
    </view>

    <view class="card card-adoption" bindtap="goToList" data-status="adoption" data-title="待领养猫猫">
      <view class="emoji">🏠</view>
      <view class="card-title">待领养</view>
      <view class="card-desc">寻找新家的猫</view>
    </view>

    <view class="card card-foster" bindtap="goToList" data-status="fostering" data-title="寄养/医治中">
      <view class="emoji">🏥</view>
      <view class="card-title">寄养/医治</view>
      <view class="card-desc">正在室内照护</view>
    </view>

    <view class="card card-adopted" bindtap="goToList" data-status="adopted" data-title="已领养的猫">
      <view class="emoji">💚</view>
      <view class="card-title">已领养</view>
      <view class="card-desc">已有幸福新家</view>
    </view>

    <view class="card card-missing" bindtap="goToList" data-status="missing" data-title="已失踪的猫">
      <view class="emoji">🔍</view>
      <view class="card-title">已失踪</view>
      <view class="card-desc">近期未见踪影</view>
    </view>

    <view class="card card-deceased" bindtap="goToList" data-status="deceased" data-title="已去世的猫">
      <view class="emoji">🌸</view>
      <view class="card-title">已去世</view>
      <view class="card-desc">永远怀念</view>
    </view>
  </view>

  <view class="footer">由热爱猫猫的同学共同维护 ♡</view>
</view>
