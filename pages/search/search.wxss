/* pages/search/search.wxss */
.container {
  padding: 24rpx 24rpx 60rpx;
  min-height: 100vh;
}

.search-box {
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.icon { font-size: 28rpx; }
.input {
  flex: 1;
  font-size: 28rpx;
}
.clear {
  color: #aaa;
  font-size: 32rpx;
  padding: 0 12rpx;
}

.hint, .result-info {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  margin: 40rpx 0 20rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 20rpx;
}
.cat-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.cat-card:active { transform: scale(0.97); }
.photo {
  width: 100%;
  height: 320rpx;
  background: #eee;
}
.info { padding: 16rpx 20rpx 20rpx; }
.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.name { font-size: 30rpx; font-weight: 600; }
.gender-male { color: #2196F3; font-size: 28rpx; }
.gender-female { color: #E91E63; font-size: 28rpx; }
.gender-unknown { color: #999; font-size: 28rpx; }

.meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #888;
}
.meta.status-current { color: #F57C00; }
.meta.status-historical { color: #3949AB; }
.meta.status-adoption { color: #00897B; }
.meta.status-fostering { color: #C2185B; }

.empty {
  margin-top: 160rpx;
  text-align: center;
  color: #999;
}
.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #bbb;
}
