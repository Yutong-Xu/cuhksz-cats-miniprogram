/* pages/list/list.wxss */
.container {
  padding: 24rpx 24rpx 60rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.cat-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  transition: transform .15s;
}
.cat-card:active {
  transform: scale(0.97);
}

.photo {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #eee;
}

.info {
  padding: 16rpx 20rpx 20rpx;
}
.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.name {
  font-size: 30rpx;
  font-weight: 600;
}
.gender-male { color: #2196F3; font-size: 28rpx; }
.gender-female { color: #E91E63; font-size: 28rpx; }
.gender-unknown { color: #999; font-size: 28rpx; }

.location {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}

.empty {
  margin-top: 200rpx;
  text-align: center;
  color: #999;
}
.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
