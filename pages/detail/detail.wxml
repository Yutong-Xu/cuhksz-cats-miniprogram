<!--pages/detail/detail.wxml-->
<view class="container">
  <!-- 照片 swiper -->
  <view class="photo-wrap">
    <swiper class="photos" indicator-dots="{{cat.photos.length > 1}}" autoplay="{{false}}" circular>
      <block wx:if="{{cat.photos.length}}">
        <swiper-item wx:for="{{cat.photos}}" wx:key="*this">
          <image class="photo" src="{{item}}" mode="aspectFill" bindtap="previewPhoto" data-url="{{item}}"/>
        </swiper-item>
      </block>
    </swiper>
    <view class="manage-photo-btn" bindtap="openPhotoManager">管理照片 ✎</view>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="name-row">
      <text class="name">{{cat.name || '...'}}</text>
      <text class="gender-{{cat.gender}}">{{cat.gender === 'male' ? '♂' : cat.gender === 'female' ? '♀' : '?'}}</text>
      <text class="edit-icon" bindtap="editField" data-field="name">✎</text>
      <text class="edit-icon" bindtap="editField" data-field="gender">✎</text>
    </view>

    <view class="tag-row">
      <view class="tag" bindtap="editField" data-field="neutered">
        <text>{{cat.neutered ? '✓ 已绝育' : '✗ 未绝育'}}</text>
        <text class="edit-icon small">✎</text>
      </view>
      <view class="tag" bindtap="editField" data-field="location">
        <text>📍 {{cat.location || '位置未知'}}</text>
        <text class="edit-icon small">✎</text>
      </view>
      <view class="tag status-{{cat.status}}" bindtap="editField" data-field="status">
        <text>{{statusText}}</text>
        <text class="edit-icon small">✎</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">
        <text>性格</text>
        <text class="edit-icon" bindtap="editField" data-field="personality">✎</text>
      </view>
      <view class="section-content">{{cat.personality || '(暂无)'}}</view>
    </view>

    <view class="section">
      <view class="section-title">
        <text>简介</text>
        <text class="edit-icon" bindtap="editField" data-field="description">✎</text>
      </view>
      <view class="section-content">{{cat.description || '(暂无)'}}</view>
    </view>
  </view>

  <!-- 删除猫咪 -->
  <view class="danger-zone">
    <text class="delete-link" bindtap="deleteCat">删除这只猫 🗑️</text>
  </view>

  <view style="height: 60rpx"></view>

  <!-- 字段编辑弹窗 -->
  <view class="modal-mask" wx:if="{{editing.visible}}" bindtap="closeEdit"></view>
  <view class="modal" wx:if="{{editing.visible}}">
    <view class="modal-title">编辑 {{editing.label}}</view>

    <input
      wx:if="{{editing.type === 'text'}}"
      class="modal-input"
      placeholder="{{editing.placeholder}}"
      value="{{editing.value}}"
      bindinput="onEditInput"
      focus="{{true}}"/>

    <textarea
      wx:if="{{editing.type === 'textarea'}}"
      class="modal-textarea"
      placeholder="{{editing.placeholder}}"
      value="{{editing.value}}"
      bindinput="onEditInput"
      auto-focus="{{true}}"/>

    <view wx:if="{{editing.type === 'radio'}}" class="modal-options">
      <view
        wx:for="{{editing.options}}" wx:key="value"
        class="pill {{editing.value === item.value ? 'pill-active' : ''}}"
        bindtap="onEditPick" data-value="{{item.value}}">
        {{item.label}}
      </view>
    </view>

    <view class="modal-actions">
      <view class="btn btn-cancel" bindtap="closeEdit">取消</view>
      <view class="btn btn-save" bindtap="saveEdit">保存</view>
    </view>
  </view>

  <!-- 照片管理弹窗 -->
  <view class="modal-mask" wx:if="{{photoManager.visible}}" bindtap="closePhotoManager"></view>
  <view class="modal photo-modal" wx:if="{{photoManager.visible}}">
    <view class="modal-title">管理照片</view>

    <view class="photo-grid">
      <view class="photo-slot" wx:for="{{photoManager.items}}" wx:key="key">
        <image src="{{item.url}}" mode="aspectFill" class="{{item.pendingDelete ? 'faded' : ''}}"/>
        <view class="photo-slot-badge" wx:if="{{item.isNew}}">新增</view>
        <view class="photo-slot-badge delete" wx:if="{{item.pendingDelete}}">将删除</view>
        <view class="photo-slot-action" catchtap="togglePhotoDelete" data-key="{{item.key}}">
          {{item.pendingDelete ? '↶' : '×'}}
        </view>
      </view>

      <view class="photo-slot add" bindtap="addPhotosInManager" wx:if="{{remainingSlots > 0}}">
        <text class="plus">+</text>
        <text class="tip">{{photoManager.items.length}}/9</text>
      </view>
    </view>

    <view class="photo-hint">点 × 标记删除,再点一次撤销。保存后生效。</view>

    <view class="modal-actions">
      <view class="btn btn-cancel" bindtap="closePhotoManager">取消</view>
      <view class="btn btn-save" bindtap="savePhotoChanges">保存</view>
    </view>
  </view>
</view>
