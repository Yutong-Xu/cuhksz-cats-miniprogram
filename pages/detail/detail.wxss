/* pages/detail/detail.wxss */
.container {
  padding-bottom: 40rpx;
}

.photos, .photo {
  width: 100%;
  height: 600rpx;
  background: #eee;
}

.card {
  background: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.name {
  font-size: 40rpx;
  font-weight: 700;
}
.gender-male { color: #2196F3; font-size: 36rpx; }
.gender-female { color: #E91E63; font-size: 36rpx; }
.gender-unknown { color: #999; font-size: 36rpx; }

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}
.tag {
  background: #F2F2F2;
  border-radius: 16rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #555;
}
.status-current { background: #FFF3E0; color: #F57C00; }
.status-historical { background: #E8EAF6; color: #3949AB; }
.status-adoption { background: #E0F2F1; color: #00897B; }
.status-fostering { background: #FCE4EC; color: #C2185B; }

.section {
  margin-top: 32rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.section-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 评论 */
.empty-comment {
  color: #999;
  font-size: 26rpx;
  text-align: center;
  padding: 40rpx 0;
}
.comment {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid #F0F0F0;
}
.comment:first-of-type {
  border-top: none;
}
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ddd;
  flex-shrink: 0;
}
.comment-main {
  flex: 1;
  min-width: 0;
}
.comment-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.nickname {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.time {
  font-size: 22rpx;
  color: #aaa;
}
.comment-text {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}
.comment-imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}
.comment-imgs image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background: #eee;
}

/* 输入栏 */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #EEE;
  z-index: 10;
}
.preview-row {
  display: flex;
  gap: 12rpx;
  padding-bottom: 16rpx;
  overflow-x: auto;
}
.preview-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}
.preview-item image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #eee;
}
.preview-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 32rpx;
  text-align: center;
  background: #000;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.input {
  flex: 1;
  background: #F2F2F2;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
}
.icon-btn {
  font-size: 44rpx;
  padding: 0 8rpx;
}
.send-btn {
  padding: 14rpx 28rpx;
  background: #DDD;
  color: #888;
  border-radius: 32rpx;
  font-size: 26rpx;
}
.send-btn.active {
  background: #FF9800;
  color: #fff;
}
