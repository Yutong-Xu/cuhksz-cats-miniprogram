/* pages/detail/detail.wxss */
.container {
  padding-bottom: 40rpx;
}

/* 照片区域 */
.photo-wrap {
  position: relative;
}
.photos, .photo {
  width: 100%;
  height: 600rpx;
  background: #eee;
}
.manage-photo-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  z-index: 2;
}

.card {
  background: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}
.name { font-size: 40rpx; font-weight: 700; }
.gender-male { color: #2196F3; font-size: 36rpx; }
.gender-female { color: #E91E63; font-size: 36rpx; }
.gender-unknown { color: #999; font-size: 36rpx; }

.edit-icon {
  color: #BBB;
  font-size: 26rpx;
  padding: 8rpx;
}
.edit-icon.small {
  font-size: 22rpx;
  padding: 0 0 0 8rpx;
  color: #999;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}
.tag {
  background: #F2F2F2;
  border-radius: 16rpx;
  padding: 8rpx 16rpx 8rpx 20rpx;
  font-size: 24rpx;
  color: #555;
  display: flex;
  align-items: center;
}
.status-current { background: #FFF3E0; color: #F57C00; }
.status-historical { background: #E8EAF6; color: #3949AB; }
.status-adoption { background: #E0F2F1; color: #00897B; }
.status-fostering { background: #FCE4EC; color: #C2185B; }

.section { margin-top: 32rpx; }
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.section-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 危险区域 */
.danger-zone {
  margin: 60rpx 20rpx 20rpx;
  text-align: center;
}
.delete-link {
  color: #E53935;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
}

/* 评论 */
.empty-comment {
  color: #999;
  font-size: 26rpx;
  text-align: center;
  padding: 40rpx 0;
}
.comment {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid #F0F0F0;
}
.comment:first-of-type { border-top: none; }
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ddd;
  flex-shrink: 0;
}
.comment-main { flex: 1; min-width: 0; }
.comment-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.nickname { font-size: 26rpx; color: #333; font-weight: 500; }
.time { font-size: 22rpx; color: #aaa; }
.comment-text {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}
.comment-imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}
.comment-imgs image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background: #eee;
}

/* 评论输入栏 */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #EEE;
  z-index: 10;
}
.preview-row {
  display: flex;
  gap: 12rpx;
  padding-bottom: 16rpx;
  overflow-x: auto;
}
.preview-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}
.preview-item image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #eee;
}
.preview-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 32rpx;
  text-align: center;
  background: #000;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}
.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.input {
  flex: 1;
  background: #F2F2F2;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
}
.icon-btn {
  font-size: 44rpx;
  padding: 0 8rpx;
}
.send-btn {
  padding: 14rpx 28rpx;
  background: #DDD;
  color: #888;
  border-radius: 32rpx;
  font-size: 26rpx;
}
.send-btn.active {
  background: #FF9800;
  color: #fff;
}

/* 编辑弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}
.modal {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
}
.modal-input {
  background: #F6F6F6;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}
.modal-textarea {
  background: #F6F6F6;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 200rpx;
  margin-bottom: 32rpx;
}
.modal-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.pill {
  padding: 14rpx 30rpx;
  background: #F2F2F2;
  color: #666;
  border-radius: 30rpx;
  font-size: 26rpx;
}
.pill-active {
  background: #FF9800;
  color: #fff;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
}
.btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.btn-cancel {
  background: #F2F2F2;
  color: #666;
}
.btn-save {
  background: linear-gradient(135deg, #FF9800, #FF6F00);
  color: #fff;
}

/* 照片管理弹窗 */
.photo-modal {
  left: 24rpx;
  right: 24rpx;
}
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 20rpx;
}
.photo-slot {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}
.photo-slot image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #eee;
}
.photo-slot image.faded {
  opacity: 0.3;
}
.photo-slot-action {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  background: #000;
  color: #fff;
  border-radius: 50%;
  font-size: 32rpx;
}
.photo-slot-badge {
  position: absolute;
  bottom: 6rpx;
  left: 6rpx;
  background: #FF9800;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}
.photo-slot-badge.delete {
  background: #E53935;
}
.photo-slot.add {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}
.photo-slot.add .plus {
  font-size: 60rpx;
  font-weight: 200;
  line-height: 1;
}
.photo-slot.add .tip {
  font-size: 20rpx;
  margin-top: 6rpx;
}
.photo-hint {
  color: #999;
  font-size: 22rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}
